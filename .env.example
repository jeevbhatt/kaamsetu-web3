# ═══════════════════════════════════════════════════════════════════════════════
# SHRAM SEWA — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in your values
# NEVER COMMIT .env.local or any file containing real secrets

# ─────────────────────────────────────────────────────────────────────────────────
# SUPABASE (Required)
# ─────────────────────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Optional: set false only when intentionally disabling backend calls.
PUBLIC_ENABLE_SUPABASE=true
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_ACCESS_TOKEN=

# OTP provider note:
# For Supabase hosted projects, configure Twilio in Supabase Dashboard:
# Authentication -> Providers -> Phone -> Twilio
# Twilio credentials are managed in Supabase dashboard, not in this client file.
# Android public runtime keys
EXPO_PUBLIC_ENABLE_SUPABASE=false
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SERVER-SIDE ONLY — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────────────────────────
# UPSTASH REDIS (Rate limiting)
# ─────────────────────────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ─────────────────────────────────────────────────────────────────────────────────
# EXPO PUSH NOTIFICATIONS (Android app)
# ─────────────────────────────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token

# ─────────────────────────────────────────────────────────────────────────────────
# CLOUDFLARE (Deployment)
# ─────────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# ─────────────────────────────────────────────────────────────────────────────────
# APP CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────────
PUBLIC_APP_NAME="Shram Sewa"
PUBLIC_APP_VERSION="0.1.0"
PUBLIC_DEFAULT_LOCALE=ne
PUBLIC_SITE_URL=https://shramsewa.jeevanbhatt.com.np
PUBLIC_WEB_URL=https://shramsewa.jeevanbhatt.com.np

# Android badge links for footer download CTA
# Prefer Play Store URL for production.
PUBLIC_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.shramsewa.android
# Optional direct APK URL for pre-release/internal distribution.
PUBLIC_ANDROID_APK_DRIVE_URL=
# Backward-compatible alias also read by footer download button.
PUBLIC_ANDROID_APK_URL=

# JWT Settings
JWT_EXPIRY_HOURS=1
REFRESH_TOKEN_DAYS=7

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Optional for auth delivery smoke test script
AUTH_TEST_PHONE_E164=+97798XXXXXXXX
AUTH_TEST_EMAIL=test@example.com
